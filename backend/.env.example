DJANGO_ENV=dev

SECRET_KEY=change-me-in-local
DEBUG=True
# Include your Render backend domain in production.
# Example: ALLOWED_HOSTS=127.0.0.1,localhost,product-sheet-backend.onrender.com
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=UTC

# Preferred: use a single DATABASE_URL (Render PostgreSQL)
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Set to True if your provider requires SSL (Render usually does).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SSL_REQUIRE=True

# Fallback local credentials (used only when DATABASE_URL is empty).
# If password contains # or special chars, wrap it in double quotes.
DB_NAME=product_sheet_db
DB_USER=your_local_db_user
DB_PASSWORD=your_local_db_password
DB_HOST=127.0.0.1
DB_PORT=5432
POSTGRES_CONN_MAX_AGE=60

CORS_ALLOWED_ORIGINS=http://localhost:3000

REDIS_URL=redis://127.0.0.1:6379/0
# Optional: set remote Redis for Render web/worker if using Celery tasks.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# Must be at least 32 characters to avoid InsecureKeyLengthWarning
JWT_SIGNING_KEY=please-change-this-jwt-signing-key-32b