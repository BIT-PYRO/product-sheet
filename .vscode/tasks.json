{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Next.js dev server",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"dev"
			],
			"isBackground": true,
			"problemMatcher": [
				"$nextjs"
			],
			"group": "build"
		},
		{
			"label": "Run Next.js dev server (npm)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"problemMatcher": [
				"$nextjs"
			],
			"group": "build"
		}
	]
}