# Google Sheets API Credentials
# Replace these values with your service account JSON key information

# Backend base URL for Next.js API routes.
# Use your Render backend URL when frontend runs locally.
# Example: BACKEND_BASE_URL=https://product-sheet-backend.onrender.com
BACKEND_BASE_URL=http://127.0.0.1:8000

GOOGLE_TYPE=service_account
GOOGLE_PROJECT_ID=your_project_id
GOOGLE_PRIVATE_KEY_ID=your_private_key_id
GOOGLE_PRIVATE_KEY=your_private_key_here
GOOGLE_CLIENT_EMAIL=your_service_account_email@iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_CLIENT_CERT_URL=your_client_cert_url

# Your Google Sheet ID (from the URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit...)
GOOGLE_SHEET_ID=your_sheet_id_here